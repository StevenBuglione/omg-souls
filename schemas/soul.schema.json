{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["id", "name", "summary", "tags", "genres", "tone", "craft", "content_boundaries", "recommended_uses", "version", "updated_at"],
  "additionalProperties": false,
  "properties": {
    "id": { "type": "string", "minLength": 1 },
    "name": { "type": "string", "minLength": 1 },
    "summary": { "type": "string", "minLength": 1 },
    "tags": { "type": "array", "items": { "type": "string" } },
    "genres": { "type": "array", "items": { "type": "string" } },
    "tone": { "type": "array", "items": { "type": "string" } },
    "craft": {
      "type": "object",
      "required": [
        "narrative_stance",
        "pov_strategy",
        "prose_rhythm",
        "scene_construction",
        "dialogue_habits",
        "emotional_palette",
        "imagery_system",
        "pacing_rules",
        "character_interiority_rules",
        "revision_checklist",
        "taboos",
        "sentence_level_strategy",
        "paragraph_rhythm",
        "scene_opening_patterns",
        "scene_closing_patterns",
        "mystery_reveal_strategy",
        "dialogue_subtext_patterns",
        "emotional_escalation_rules",
        "forbidden_prose_moves",
        "revision_rubric",
        "sample_scene_fragments",
        "style_critic_checklist",
        "art_direction_language",
        "examples"
      ],
      "additionalProperties": false,
      "properties": {
        "narrative_stance": { "type": "string", "minLength": 1 },
        "pov_strategy": { "type": "string", "minLength": 1 },
        "prose_rhythm": { "type": "string", "minLength": 1 },
        "scene_construction": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
        "dialogue_habits": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
        "emotional_palette": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
        "imagery_system": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
        "pacing_rules": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
        "character_interiority_rules": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
        "revision_checklist": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
        "taboos": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
        "sentence_level_strategy": { "type": "array", "items": { "type": "string" }, "minItems": 2 },
        "paragraph_rhythm": { "type": "array", "items": { "type": "string" }, "minItems": 2 },
        "scene_opening_patterns": { "type": "array", "items": { "type": "string" }, "minItems": 2 },
        "scene_closing_patterns": { "type": "array", "items": { "type": "string" }, "minItems": 2 },
        "mystery_reveal_strategy": { "type": "array", "items": { "type": "string" }, "minItems": 2 },
        "dialogue_subtext_patterns": { "type": "array", "items": { "type": "string" }, "minItems": 2 },
        "emotional_escalation_rules": { "type": "array", "items": { "type": "string" }, "minItems": 2 },
        "forbidden_prose_moves": { "type": "array", "items": { "type": "string" }, "minItems": 2 },
        "revision_rubric": { "type": "array", "items": { "type": "string" }, "minItems": 2 },
        "sample_scene_fragments": { "type": "array", "items": { "type": "string" }, "minItems": 2 },
        "style_critic_checklist": { "type": "array", "items": { "type": "string" }, "minItems": 2 },
        "art_direction_language": { "type": "array", "items": { "type": "string" }, "minItems": 2 },
        "examples": {
          "type": "object",
          "required": ["good", "bad"],
          "additionalProperties": false,
          "properties": {
            "good": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
            "bad": { "type": "array", "items": { "type": "string" }, "minItems": 1 }
          }
        }
      }
    },
    "content_boundaries": { "type": "array", "items": { "type": "string" } },
    "recommended_uses": { "type": "array", "items": { "type": "string" } },
    "version": { "type": "string", "minLength": 1 },
    "updated_at": { "type": "string", "minLength": 1 }
  }
}
